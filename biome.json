{
	"$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"noNonNullAssertion": "off"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"overrides": [
		{
			"includes": ["src/css/*.css"],
			"linter": {
				"rules": {
					"correctness": {
						"noUnknownFunction": "off"
					},
					"suspicious": {
						"noUnknownAtRules": "off"
					}
				}
			}
		}
	],
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"html": {
		"parser": {
			"interpolation": true
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	}
}
