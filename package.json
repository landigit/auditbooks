{
  "name": "auditbooks",
  "version": "0.36.1",
  "description": "Premium standalone accounting app for everyone",
  "main": "dist-electron/main.js",
  "type": "module",
  "author": {
    "name": "Landigit Agency",
    "email": "landigitagency@gmail.com"
  },
  "scripts": {
    "dev": "vite",
    "build": "yarn run validate && vite build",
    "preview": "vite preview",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check --write .",
    "type-check": "vue-tsc --noEmit",
    "db:codegen": "bunx kysely-codegen --dialect sqlite --out-file src/types/db.d.ts --url ./demo.db",
    "db:verify": "bunx kysely-codegen --dialect sqlite --out-file src/types/db.d.ts --url ./demo.db --verify",
    "validate": "yarn run check && yarn run db:verify && bun run type-check"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.4.2",
    "@codemirror/lang-vue": "^0.1.1",
    "@popperjs/core": "^2.10.2",
    "better-sqlite3": "^11.5.0",
    "bree": "^9.2.4",
    "codemirror": "^6.0.1",
    "core-js": "^3.19.0",
    "electron-store": "^8.0.1",
    "feather-icons": "^4.28.0",
    "hono": "^4.0.0",
    "knex": "^3.2.4",
    "lodash": "^4.17.23",
    "luxon": "^2.5.2",
    "node-fetch": "2",
    "pesa": "^1.1.12",
    "source-map-support": "^0.5.21",
    "vue": "^3.5.30",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@codemirror/language": "^6.0.0",
    "@codemirror/state": "^6.0.0",
    "@codemirror/view": "^6.0.0",
    "@electron/rebuild": "^3.4.1",
    "@lezer/common": "^1.0.0",
    "@types/assert": "^1.5.6",
    "@types/better-sqlite3": "^7.6.4",
    "@types/electron-devtools-installer": "^2.2.0",
    "@types/lodash": "^4.14.179",
    "@types/luxon": "^2.3.1",
    "@types/node": "^17.0.23",
    "@types/node-fetch": "^2.6.1",
    "@types/tape": "^4.13.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "autoprefixer": "^10.4.19",
    "chokidar": "^3.5.3",
    "dotenv": "^16.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^24.9.1",
    "electron-devtools-installer": "^3.2.0",
    "electron-updater": "^6.3.0",
    "execa": "^7.1.1",
    "fs-extra": "^11.1.1",
    "kysely": "^0.28.14",
    "kysely-codegen": "^0.20.0",
    "playwright": "^1.55.1",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.17",
    "tailwindcss-rtl": "^0.9.0",
    "tap-spec": "^5.0.0",
    "tape": "^5.6.1",
    "ts-node": "^10.7.0",
    "tsconfig-paths": "^3.14.1",
    "tslib": "^2.3.1",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vue-tsc": "^3.2.6",
    "yargs": "^17.7.2"
  },
  "resolutions": {
    "node-abi": "^3.54.0"
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5",
    "endOfLine": "auto"
  },
  "homepage": "https://www.landigit.com/auditbooks",
  "repository": {
    "url": "https://github.com/landigit/auditbooks"
  },
  "license": "AGPL-3.0-only",
  "trustedDependencies": [
    "core-js",
    "better-sqlite3"
  ],
  "packageManager": "yarn@4.13.0"
}
